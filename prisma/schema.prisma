// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  password    String?
  role        String       @default("user") // "admin" or "user"
  createdAt   DateTime     @default(now()) @db.Timestamp(6)

  // Add more fields as needed for gym app
  workouts      Workout[]
  attendances   Attendance[]
  profile       UserProfile?
  weeklyRoutines WeeklyRoutine[]
}

model Workout {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  exercises   Exercise[]
  createdAt   DateTime @default(now()) @db.Timestamp(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id          String   @id @default(cuid())
  workoutId   String
  name        String
  sets        Int?
  reps        Int?
  weight      Float?
  restTime    Int?     // Rest time in seconds
  notes       String?  // Additional notes for the exercise

  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model DailyExercise {
  id            String   @id @default(cuid())
  dailyRoutineId String
  name          String
  sets          Int?
  reps          Int?
  weight        Float?
  restTime      Int?     // Rest time in seconds
  notes         String?  // Additional notes for the exercise
  order         Int      @default(0) // Order in the routine

  dailyRoutine  DailyRoutine @relation(fields: [dailyRoutineId], references: [id], onDelete: Cascade)
}

model Attendance {
  id        String   @id @default(cuid())
  userId    String
  date      String   // Formato: YYYY-MM-DD
  timestamp DateTime @default(now()) @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date]) // Un usuario solo puede tener una asistencia por día
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  level           String   @default("beginner") // beginner, intermediate, advanced
  goals           String[] // ["weight_loss", "muscle_gain", "strength", "endurance", "maintenance"]
  availableDays   Int      @default(3) // days per week available for training
  sessionDuration Int      @default(60) // minutes per session
  equipment       String[] // ["dumbbells", "barbell", "machines", "bodyweight", "resistance_bands"]
  restDays        Int[]    @default([0, 6]) // days of week to rest [0=Sunday, 6=Saturday]
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @updatedAt @db.Timestamp(6)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyRoutine {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isActive    Boolean  @default(true)
  type        String   @default("custom") // "auto" or "custom"
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @db.Timestamp(6)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyRoutines DailyRoutine[]
}

model DailyRoutine {
  id              String   @id @default(cuid())
  weeklyRoutineId String
  dayOfWeek       Int      // 0-6 (Sunday-Saturday)
  name            String   // e.g., "Full Body Day 1", "Upper Body"
  duration        Int?     // Estimated duration in minutes
  createdAt       DateTime @default(now()) @db.Timestamp(6)
  updatedAt       DateTime @updatedAt @db.Timestamp(6)

  weeklyRoutine   WeeklyRoutine @relation(fields: [weeklyRoutineId], references: [id], onDelete: Cascade)
  exercises       DailyExercise[]
}